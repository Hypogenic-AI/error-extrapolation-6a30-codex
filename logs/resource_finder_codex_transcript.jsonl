{"type":"item.started","item":{"id":"item_136","type":"command_execution","command":"/bin/bash -lc \"HF_HOME=/workspaces/error-extrapolation-6a30-codex/datasets/.hf_home uv run python - <<'PY'\nfrom pathlib import Path\nimport json, zipfile\nfrom datasets import load_dataset, DatasetDict\nfrom huggingface_hub import hf_hub_download\n\nroot = Path('datasets')\nroot.mkdir(exist_ok=True)\n\ndef slim(obj, max_text=1200):\n    if isinstance(obj, dict):\n        return {k: slim(v, max_text) for k, v in obj.items()}\n    if isinstance(obj, list):\n        return [slim(v, max_text) for v in obj[:5]]\n    if isinstance(obj, str):\n        return obj if len(obj) <= max_text else obj[:max_text] + ' ...[truncated]'\n    return obj\n\ndef save_sample(ds, outdir, n=3):\n    sample_dir = outdir / 'samples'\n    sample_dir.mkdir(parents=True, exist_ok=True)\n    records = {}\n    if isinstance(ds, DatasetDict):\n        for split, split_ds in ds.items():\n            records[split] = [slim(split_ds[i]) for i in range(min(n, len(split_ds)))]\n    else:\n        records['data'] = [slim(ds[i]) for i in range(min(n, len(ds)))]\n    with (sample_dir / 'sample_records.json').open('w') as f:\n        json.dump(records, f, indent=2)\n\nconfigs = [\n    ('ccdv/govreport-summarization', 'document', 'govreport_summarization'),\n    ('pszemraj/qmsum-cleaned', 'default', 'qmsum_cleaned'),\n    ('pszemraj/SQuALITY-v1.3', 'default', 'squality_v1_3'),\n    ('mtc/frank-test-set-with-faithfulness-annotation', 'default', 'frank_factuality_annotations'),\n]\nfor name, config, dirname in configs:\n    outdir = root / dirname\n    print(f'Loading {name} ({config})')\n    ds = load_dataset(name, config)\n    ds.save_to_disk(str(outdir))\n    save_sample(ds, outdir)\n    print(f'Saved {dirname}: {ds}')\n\nprint('Downloading LongBench data.zip')\nlongbench_dir = root / 'longbench'\nlongbench_dir.mkdir(parents=True, exist_ok=True)\nzip_path = hf_hub_download(repo_id='zai-org/LongBench', filename='data.zip', repo_type='dataset', local_dir=str(longbench_dir / 'raw'))\nwith zipfile.ZipFile(zip_path) as zf:\n    zf.extractall(longbench_dir / 'extracted')\n# Save small samples from summarization-related jsonl files if present.\nsample_dir = longbench_dir / 'samples'\nsample_dir.mkdir(exist_ok=True)\nselected = []\nfor path in sorted((longbench_dir / 'extracted').rglob('*.jsonl')):\n    if any(key in path.name.lower() for key in ['gov_report', 'qmsum', 'multi_news', 'vcsum']):\n        selected.append(path)\nsummary = {}\nfor path in selected[:8]:\n    rows=[]\n    with path.open() as f:\n        for _, line in zip(range(3), f):\n            rows.append(slim(json.loads(line)))\n    summary[str(path.relative_to(longbench_dir))] = rows\nwith (sample_dir / 'sample_records.json').open('w') as f:\n    json.dump(summary, f, indent=2)\nprint('Saved longbench files:', len(list((longbench_dir / 'extracted').rglob('*'))))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
