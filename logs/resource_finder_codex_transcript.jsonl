-hier-cleaned.json\ncode/BooookScore/summaries/README.md\ncode/BooookScore/summaries/chatgpt-2048-hier-cleaned.json\ncode/BooookScore/summaries/chatgpt-2048-hier.json\ncode/BooookScore/summaries/chatgpt-2048-inc-cleaned.json\ncode/BooookScore/summaries/chatgpt-2048-inc.json\ncode/BooookScore/summaries/claude-2048-hier-cleaned.json\ncode/BooookScore/summaries/claude-2048-hier.json\ncode/BooookScore/summaries/claude-2048-inc-cleaned.json\ncode/BooookScore/summaries/claude-2048-inc.json\ncode/BooookScore/summaries/claude-88000-hier-cleaned.json\ncode/BooookScore/summaries/claude-88000-hier.json\ncode/BooookScore/summaries/claude-88000-inc-cleaned.json\ncode/BooookScore/summaries/claude-88000-inc.json\ncode/BooookScore/summaries/gpt4-2048-hier-cleaned.json\ncode/BooookScore/summaries/gpt4-2048-hier.json\ncode/BooookScore/summaries/gpt4-2048-inc-cleaned.json\ncode/BooookScore/summaries/gpt4-2048-inc.json\ncode/BooookScore/summaries/gpt4-4096-hier-cleaned.json\ncode/BooookScore/summaries/gpt4-4096-hier.json\ncode/BooookScore/summaries/gpt4-4096-inc-cleaned.json\ncode/BooookScore/summaries/gpt4-4096-inc.json\ncode/BooookScore/summaries/llama2-2048-hier-cleaned.json\ncode/BooookScore/summaries/llama2-2048-hier.json\ncode/BooookScore/summaries/mixtral_2048_hier.json\ncode/BooookScore/summaries/mixtral_2048_hier_cleaned.json\ncode/BooookScore/summaries/mixtral_2048_inc.json\ncode/BooookScore/summaries/mixtral_2048_inc_cleaned.json\ncode/LongDocFACTScore/data/README.md\ncode/LongDocFACTScore/data/raw_data/example_text_file.txt\ncode/frank/data/baseline_factuality_metrics_outputs.json\ncode/frank/data/benchmark_data.json\ncode/frank/data/example_benchmark_data_scored.json\ncode/frank/data/example_metrics_outputs_info.json\ncode/frank/data/human_annotations.json\ncode/frank/data/human_annotations_sentence.json\ncode/frank/data/selected_documents.txt\ncode/frank/data/test_split.txt\ncode/frank/data/validation_split.txt\n","exit_code":0,"status":"completed"}}
